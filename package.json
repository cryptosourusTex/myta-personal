{
  "name": "myta-personal",
  "private": true,
  "workspaces": ["web", "worker"],
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:worker": "npm run dev --workspace=worker",
    "build": "npm run build --workspace=web && npm run build --workspace=worker",
    "build:web": "npm run build --workspace=web",
    "build:worker": "npm run build --workspace=worker",
    "db:migrate": "npm run db:migrate --workspace=worker",
    "deploy": "npm run deploy --workspace=worker && npm run deploy --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
